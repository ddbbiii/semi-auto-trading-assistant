TRADING_ASSISTANT_LLM_API_KEY=
TRADING_ASSISTANT_LLM_MODEL=
TRADING_ASSISTANT_VISION_IMPORT_ENABLED=0
TRADING_ASSISTANT_LLM_API_STYLE=chat_completions
TRADING_ASSISTANT_EMAIL_ALERTS=0
TRADING_ASSISTANT_ALERT_EMAIL_TO=
TRADING_ASSISTANT_SMTP_HOST=
