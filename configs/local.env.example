# Runtime and storage
TRADING_ASSISTANT_DATA_DIR=data/runtime
TRADING_ASSISTANT_DATABASE_URL=sqlite:///data/runtime/trading-assistant.sqlite3
TRADING_ASSISTANT_SCHEDULER_ENABLED=1
TRADING_ASSISTANT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Quotes: Futu OpenD is primary; Finnhub is fallback.
TRADING_ASSISTANT_FUTU_ENABLED=0
TRADING_ASSISTANT_FUTU_HOST=127.0.0.1
TRADING_ASSISTANT_FUTU_PORT=11111
TRADING_ASSISTANT_FINNHUB_API_KEY=
TRADING_ASSISTANT_OFFICIAL_EVIDENCE_ENABLED=1
TRADING_ASSISTANT_OFFICIAL_EVIDENCE_LOOKBACK_DAYS=180
TRADING_ASSISTANT_SEC_USER_AGENT=OpenStock personal-investment-desk contact@example.invalid

# Optional OpenAI-compatible explanation layer. It cannot alter numeric decisions.
TRADING_ASSISTANT_LLM_BASE_URL=
TRADING_ASSISTANT_LLM_API_KEY=
TRADING_ASSISTANT_LLM_MODEL=
TRADING_ASSISTANT_VISION_IMPORT_ENABLED=0
TRADING_ASSISTANT_LLM_API_STYLE=chat_completions

# Optional urgent-only email alerts.
TRADING_ASSISTANT_EMAIL_ALERTS=0
TRADING_ASSISTANT_ALERT_EMAIL_TO=
TRADING_ASSISTANT_SMTP_HOST=smtp.gmail.com
TRADING_ASSISTANT_SMTP_PORT=587
TRADING_ASSISTANT_SMTP_USERNAME=
TRADING_ASSISTANT_SMTP_PASSWORD=
TRADING_ASSISTANT_SMTP_FROM=
TRADING_ASSISTANT_SMTP_USE_TLS=1
